PORT=5000
MONGODB_URI=mongodb://localhost:27017/yoga-studio
JWT_SECRET=your_jwt_secret_change_in_production
JWT_ACCESS_SECRET=your_access_secret_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_DAYS=7
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# First-time studio setup (real data mode — default)
ADMIN_EMAIL=owner@yogastudio.com
ADMIN_PASSWORD=change_me_on_first_login
ADMIN_NAME=Studio Owner
ADMIN_PHONE=9999999999
STUDIO_ID=default
